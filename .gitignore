# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Node / frontend
node_modules/
frontend/node_modules/
frontend/dist/
*.log

# TLS certificates — generated at runtime by ./mailmind (mkcert or openssl).
# Never commit; each machine needs its own cert with the correct LAN IP.
frontend/cert.pem
frontend/key.pem

# MailMind runtime data (NEVER commit — contains secrets / user data)
.mailmind/
backend/.mailmind/
# Encrypted OAuth tokens (Fernet) — still secret, never commit.
backend/accounts.json
**/accounts.json

# Gmail OAuth client secrets — user-provided, must not be committed.
backend/credentials.json
**/credentials.json

# OS noise
.DS_Store
Thumbs.db
