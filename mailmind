#!/usr/bin/env bash
# MailMind — single-command launcher.
#
# Ensures deps, builds the frontend, starts ONE uvicorn process that serves both
# the API and the built SPA on http://localhost:8000.
#
# Usage:
#   ./mailmind            start (foreground, Ctrl-C to stop)
#   ./mailmind --dev      dev mode: two processes (Vite HMR + backend)
#   ./mailmind --build    only build the frontend, don't start
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

DEV_MODE=false
BUILD_ONLY=false
case "${1:-}" in
  --dev)    DEV_MODE=true ;;
  --build)  BUILD_ONLY=true ;;
esac

# ---- preflight: Python ----------------------------------------------------
if [[ ! -d backend/.venv ]]; then
  echo "→ Creating Python venv…"
  python3 -m venv backend/.venv
  backend/.venv/bin/pip install --upgrade pip -q
fi
if ! backend/.venv/bin/pip show fastapi -q >/dev/null 2>&1; then
  echo "→ Installing Python deps…"
  backend/.venv/bin/pip install -r requirements.txt -q
fi

# ---- preflight: frontend build --------------------------------------------
DIST="frontend/dist"
NEEDS_BUILD=false
if [[ ! -d "$DIST" ]] || [[ ! -f "$DIST/index.html" ]]; then
  NEEDS_BUILD=true
fi
if [[ "$NEEDS_BUILD" == true || "$BUILD_ONLY" == true ]]; then
  if [[ ! -d frontend/node_modules ]]; then
    echo "→ Installing frontend deps…"
    (cd frontend && npm install)
  fi
  echo "→ Building frontend…"
  (cd frontend && npm run build)
  echo "→ Built to $DIST/"
fi
if [[ "$BUILD_ONLY" == true ]]; then
  exit 0
fi

# ---- run ------------------------------------------------------------------
CHILDREN=()
cleanup() {
  echo; echo "→ Stopping MailMind…"
  # Kill tracked children and their process groups.
  for pid in "${CHILDREN[@]}"; do
    kill -- -"$pid" 2>/dev/null || kill "$pid" 2>/dev/null || true
  done
  # Fallback: kill anything still in our process group.
  kill 0 2>/dev/null || true
  sleep 0.5
  # Force-kill survivors.
  for pid in "${CHILDREN[@]}"; do
    kill -9 "$pid" 2>/dev/null || true
  done
}
trap cleanup EXIT INT TERM

# ---- preflight: TLS certificate (for PWA / HTTPS) ---------------------------
CERT_DIR="$ROOT/frontend"
CERT="$CERT_DIR/cert.pem"
KEY="$CERT_DIR/key.pem"

# current_lan_ip — detect the machine's LAN IP.
current_lan_ip() {
  hostname -I 2>/dev/null | awk '{print $1}'
}

# cert_covers_ip — check if the cached cert's SANs include the given IP.
# Returns 0 (true) if the IP is found, 1 (false) otherwise.
cert_covers_ip() {
  local ip="$1"
  [[ -z "$ip" ]] && return 1
  [[ ! -f "$CERT" ]] && return 1
  # Extract SANs and grep for the IP (matches both IP:x.x.x.x and bare IP).
  openssl x509 -noout -ext subjectAltName -in "$CERT" 2>/dev/null \
    | grep -q "$ip"
}

# needs_cert_regen — true if cert is missing or doesn't cover current LAN IP.
needs_cert_regen() {
  if [[ ! -f "$CERT" || ! -f "$KEY" ]]; then
    return 0
  fi
  local lan
  lan=$(current_lan_ip)
  if [[ -n "$lan" ]] && ! cert_covers_ip "$lan"; then
    echo "⚠ LAN IP changed to $lan — regenerating TLS certificate…"
    return 0
  fi
  return 1
}

if needs_cert_regen; then
  LAN_IP_TEMP=$(current_lan_ip)
  if [[ -n "$LAN_IP_TEMP" ]]; then
    CERT_HOSTS="localhost 127.0.0.1 $LAN_IP_TEMP"
  else
    CERT_HOSTS="localhost 127.0.0.1"
  fi
  # Remove stale certs so mkcert/openssl don't append to existing files.
  rm -f "$CERT" "$KEY"
  if command -v mkcert >/dev/null 2>&1; then
    echo "→ Generating trusted TLS certificate via mkcert…"
    mkcert -install 2>/dev/null
    mkcert -cert-file "$CERT" -key-file "$KEY" $CERT_HOSTS
    echo "✓ Certificate saved to $CERT (trusted by this machine)"
    echo "  To trust on your phone, install the CA cert on it:"
    echo "  $(mkcert -CAROOT)/rootCA.pem"
  else
    echo "→ mkcert not found — generating self-signed cert (browser will warn)…"
    echo "  For a warning-free experience, install mkcert:"
    echo "  https://github.com/FiloSottile/mkcert"
    SAN_EXT="DNS:localhost,IP:127.0.0.1"
    if [[ -n "$LAN_IP_TEMP" ]]; then
      SAN_EXT="$SAN_EXT,IP:$LAN_IP_TEMP"
    fi
    openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:P-256 \
      -keyout "$KEY" -out "$CERT" -days 3650 -nodes \
      -subj "/CN=MailMind" -addext "subjectAltName=$SAN_EXT" \
    2>/dev/null
    echo "✓ Certificate saved to $CERT"
  fi
fi

# ---- preflight: Ollama ----------------------------------------------------
# Auto-start the local LLM so triage/summaries work out of the box. If Ollama
# is already running (or not installed), we continue either way.
#
# OLLAMA_KEEP_ALIVE bounds how long the model stays resident in RAM between
# requests — set to a short window so a long rescan doesn't pin memory the
# whole time, and idle RAM is freed after the scan finishes.
export OLLAMA_KEEP_ALIVE="${OLLAMA_KEEP_ALIVE:-5m}"
OLLAMA_URL="http://localhost:11434"
if curl -sf "$OLLAMA_URL/api/tags" >/dev/null 2>&1; then
  echo "→ Ollama already running."
elif command -v ollama >/dev/null 2>&1; then
  echo "→ Starting Ollama…"
  ollama serve >/dev/null 2>&1 &
  OLLAMA_PID=$!
  # Wait up to 15s for the API to come up.
  for i in $(seq 1 15); do
    if curl -sf "$OLLAMA_URL/api/tags" >/dev/null 2>&1; then
      echo "✓ Ollama ready."
      break
    fi
    sleep 1
    [[ $i -eq 15 ]] && echo "→ Ollama slow to start — triage features may be delayed."
  done
else
  echo "→ Ollama not found — triage features will be unavailable."
  echo "  Install from https://ollama.com to enable AI summaries & ratings."
fi

if [[ "$DEV_MODE" == true ]]; then
  echo "→ [dev mode] Starting backend on :8000 and Vite on :5173…"
  backend/.venv/bin/python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000 \
    --ssl-keyfile "$KEY" --ssl-certfile "$CERT" & CHILDREN+=($!)
  (cd frontend && npm run dev) & CHILDREN+=($!)
  sleep 3
  URL="https://localhost:5173"
  LAN_PORT=5173
else
  echo "→ Starting MailMind on :8000 …"
  backend/.venv/bin/python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000 \
    --ssl-keyfile "$KEY" --ssl-certfile "$CERT" & CHILDREN+=($!)
  URL="https://localhost:8000"
  LAN_PORT=8000
fi

sleep 2

# ---- LAN IP detection -------------------------------------------------------
LAN_IP=$(hostname -I 2>/dev/null | awk '{print $1}')
if [[ -z "$LAN_IP" ]]; then
  LAN_IP=$(ip route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}' | head -1)
fi

# Open browser if possible.
if command -v xdg-open >/dev/null 2>&1; then
  (xdg-open "$URL" >/dev/null 2>&1 &) || true
elif command -v open >/dev/null 2>&1; then
  (open "$URL" >/dev/null 2>&1 &) || true
fi

echo
echo "✓ MailMind running at $URL"
if [[ -n "$LAN_IP" ]]; then
  echo "  LAN: https://$LAN_IP:$LAN_PORT"
  echo "  (open on other devices via the LAN address above)"
  echo "  If unreachable, run: sudo ufw allow $LAN_PORT"
fi
echo "  Note: self-signed cert — your browser may show a warning."
echo "  (Ctrl-C to stop)"
echo
wait
